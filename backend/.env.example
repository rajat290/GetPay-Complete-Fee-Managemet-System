PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/getpay
# MONGO_URI is still supported as a legacy alias, but MONGODB_URI is preferred.
JWT_SECRET=replace_with_a_long_random_secret
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
LOG_FORMAT=pretty
LOG_LEVEL=info
APP_VERSION=local
ERROR_TRACKING_PROVIDER=logger
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
PUBLIC_STUDENT_REGISTRATION_ENABLED=false
SUPER_ADMIN_NAME=Platform Owner
SUPER_ADMIN_EMAIL=owner@getpay.example
SUPER_ADMIN_PASSWORD=replace_with_a_strong_password

RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_me

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=notifications@example.com
EMAIL_PASS=replace_me
